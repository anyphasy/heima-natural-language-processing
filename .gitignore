# 只忽略模型权重类大文件（核心）
*.pth
*.pt
*.pkl
*.h5
*.ckpt
*.bin
*.mp4
*.mp3
# 忽略大体积压缩包（可选，根据需求保留/删除）
*.zip
*.rar
*.7z
*.tar.gz

# 忽略Python编译文件（必选，减小仓库体积）
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 忽略系统/编辑器文件（必选，避免无用文件提交）
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 忽略日志/缓存文件（可选）
*.log
*.tmp
*.cache